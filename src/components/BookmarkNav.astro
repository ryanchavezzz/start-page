---
import { getFavoriteBookmarks } from "../lib/bookmarks";
import BookmarkIcon from "./BookmarkIcon.astro";

const favorites = getFavoriteBookmarks();
---

<nav class="favorites-bar" aria-label="Favorite bookmarks">
  <ul>
    {
      favorites.map((link) => (
        <li>
          <a href={link.href}>
            <BookmarkIcon link={link} />
            <span>{link.title}</span>
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .favorites-bar {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  ul {
    display: flex;
    flex-wrap: nowrap;
    justify-content: center;
    list-style: none;
  }

  li {
    position: relative;
  }

  li:not(:first-child) {
    margin-left: -1px;
  }

  li:hover {
    z-index: 1;
  }

  a {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border-radius: 0;
    border: 1px solid var(--border);
    background: var(--surface-translucent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    color: var(--text);
    text-decoration: none;
    font-family: var(--font);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: -0.01em;
    transition:
      background var(--transition),
      border-color var(--transition);
  }

  li:first-child a {
    border-radius: var(--radius) 0 0 var(--radius);
  }

  li:last-child a {
    border-radius: 0 var(--radius) var(--radius) 0;
  }

  a:hover {
    background: var(--hover);
  }

  @media (max-width: 480px) {
    a {
      padding: 7px 12px;
      font-size: 13px;
    }
  }
</style>
