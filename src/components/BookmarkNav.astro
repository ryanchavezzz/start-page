---
import { getFavoriteBookmarks } from "../lib/bookmarks";
import BookmarkIcon from "./BookmarkIcon.astro";

const favorites = getFavoriteBookmarks();
---

<nav class="favorites-bar" aria-label="Favorite bookmarks">
  <ul>
    {
      favorites.map((link) => (
        <li>
          <a href={link.href} title={link.title} aria-label={link.title}>
            <BookmarkIcon link={link} />
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .favorites-bar {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  ul {
    display: flex;
    flex-wrap: nowrap;
    gap: 8px;
    justify-content: center;
    list-style: none;
  }

  a {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid transparent;
    background: transparent;
    color: var(--text);
    text-decoration: none;
    transition:
      background var(--transition),
      border-color var(--transition),
      transform var(--transition);
  }

  a:hover {
    background: var(--hover);
    border-color: var(--border);
    transform: scale(1.05);
  }
</style>
