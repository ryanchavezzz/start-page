---
type Bookmark = {
  href: string;
  title: string;
  alt?: string;
  src?: string;
  srcLight?: string;
  srcDark?: string;
  category?: string;
  androidApp?: string;
  iosScheme?: string;
};

const modules = import.meta.glob<{ frontmatter: { links: Bookmark[] } }>(
  "../content/bookmarks.md",
  { eager: true },
);
const links: Bookmark[] = Object.values(modules)[0].frontmatter.links;

// Group by category (in first-appearance order) so related bookmarks land
// in the same box, without ever rendering the category itself as a label.
const groups = new Map<string, Bookmark[]>();
for (const link of links) {
  const key = link.category ?? "other";
  const group = groups.get(key);
  if (group) {
    group.push(link);
  } else {
    groups.set(key, [link]);
  }
}
const sections: Bookmark[][] = Array.from(groups.values());

const categoryLabels: Record<string, string> = {
  mail: "Mail",
  google: "Google",
  accounts: "Accounts",
  dev: "Dev",
  media: "Media",
  printing: "3D Print",
  shopping: "Shopping",
  torrents: "Torrents",
  misc: "Tools",
};
---

<section class="bookmark-sections">
  {
    sections.map((section) => (
      <div class="bookmark-section">
        <p class="section-label">{categoryLabels[section[0].category ?? ""] ?? section[0].category ?? "Other"}</p>
        <ul>
          {section.map((link) => (
            <li>
              <a
                href={link.href}
                data-android-app={link.androidApp}
                data-ios-scheme={link.iosScheme}
              >
                {link.srcLight && link.srcDark ? (
                  <>
                    <img
                      class="svg-icon icon-light"
                      src={link.srcLight}
                      alt={link.alt}
                    />
                    <img
                      class="svg-icon icon-dark"
                      src={link.srcDark}
                      alt={link.alt}
                    />
                  </>
                ) : link.src ? (
                  <img class="svg-icon" src={link.src} alt={link.alt} />
                ) : (
                  <span class="icon-placeholder" aria-hidden="true" />
                )}
                <span>{link.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))
  }
</section>

<style>
  .bookmark-sections {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 240px));
    justify-content: center;
    gap: 16px;
    width: 100%;
  }

  .bookmark-section {
    background: var(--surface-translucent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
    padding: 12px;
  }

  .section-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 2px 4px 8px;
    margin: 0;
  }

  ul {
    list-style: none;
    display: grid;
    gap: 6px;
  }

  ul li a {
    color: var(--text);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 14px;
    border-radius: var(--radius);
    background: transparent;
    font-size: 16px;
    transition:
      background var(--transition),
      transform var(--transition),
      box-shadow var(--transition);
  }

  ul li a:hover {
    background: var(--hover);
    transform: translateX(2px);
  }

  ul li a img {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
    filter: var(--icon-filter);
    transition: filter var(--transition);
  }

  ul li a img.icon-light,
  ul li a img.icon-dark {
    filter: none;
  }

  :root[data-theme="light"] ul li a img.icon-light {
    display: none;
  }

  :root[data-theme="dark"] ul li a img.icon-dark {
    display: none;
  }

  ul li a .icon-placeholder {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  ul li a span {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (max-width: 480px) {
    .bookmark-sections {
      grid-template-columns: 1fr;
    }
    ul li a {
      padding: 10px 12px;
      font-size: 15px;
    }
  }
</style>

<script>
  const ua = navigator.userAgent;
  const isAndroid = /Android/i.test(ua);
  const isIOS = /iPhone|iPad|iPod/i.test(ua);

  document
    .querySelectorAll<HTMLAnchorElement>(
      "a[data-android-app], a[data-ios-scheme]",
    )
    .forEach((link) => {
      const androidApp = link.dataset.androidApp;
      const iosScheme = link.dataset.iosScheme;
      const webUrl = link.href;

      if (isAndroid && androidApp) {
        link.addEventListener("click", (event) => {
          event.preventDefault();
          const host = webUrl.replace(/^https?:\/\//, "");
          window.location.href =
            `intent://${host}#Intent;scheme=https;package=${androidApp};` +
            `S.browser_fallback_url=${encodeURIComponent(webUrl)};end`;
        });
      } else if (isIOS && iosScheme) {
        link.addEventListener("click", (event) => {
          event.preventDefault();
          const start = Date.now();
          window.location.href = iosScheme;
          setTimeout(() => {
            if (!document.hidden && Date.now() - start < 2000) {
              window.location.href = webUrl;
            }
          }, 800);
        });
      }
      // Desktop (or any device without a matching app link): fall through
      // to the normal href navigation to the website.
    });
</script>
