---
import { getBookmarkSections } from "../lib/bookmarks";
import BookmarkIcon from "./BookmarkIcon.astro";

// Grouped by category (in first-appearance order) so related bookmarks land
// in the same box, without ever rendering the category itself as a label.
const sections = getBookmarkSections();
---

<section class="bookmark-sections">
  {
    sections.map((section) => (
      <div class="bookmark-section">
        <ul>
          {section.links.map((link) => (
            <li>
              <a href={link.href}>
                <BookmarkIcon link={link} />
                <span>{link.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))
  }
</section>

<style>
  .bookmark-sections {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 240px));
    justify-content: center;
    gap: 16px;
    width: 100%;
  }

  .bookmark-section {
    background: var(--surface-translucent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
    padding: 12px;
  }

  ul {
    list-style: none;
    display: grid;
    gap: 6px;
  }

  ul li a {
    color: var(--text);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    border-radius: var(--radius);
    background: transparent;
    font-size: 14px;
    transition:
      background var(--transition),
      transform var(--transition),
      box-shadow var(--transition);
  }

  ul li a:hover {
    background: var(--hover);
    transform: translateX(2px);
  }

  ul li a span {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (max-width: 480px) {
    .bookmark-sections {
      grid-template-columns: 1fr;
    }
    ul li a {
      padding: 9px 12px;
      font-size: 13px;
    }
  }
</style>
