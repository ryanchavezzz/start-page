---
import { getBookmarkSections } from "../lib/bookmarks";
import BookmarkIcon from "./BookmarkIcon.astro";

const sections = getBookmarkSections();
---

<section class="bookmark-sections">
  {
    sections.map((section) => (
      <div class="bookmark-section">
        <ul>
          {section.links.map((link) => (
            <li>
              <a
                href={link.href}
                data-android-app={link.androidApp}
                data-ios-scheme={link.iosScheme}
              >
                <BookmarkIcon link={link} />
                <span>{link.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))
  }
</section>

<style>
  .bookmark-sections {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 240px));
    justify-content: center;
    gap: 16px;
    width: 100%;
  }

  .bookmark-section {
    background: var(--surface-translucent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
    padding: 12px;
  }

  ul {
    list-style: none;
    display: grid;
    gap: 6px;
  }

  ul li a {
    color: var(--text);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    border-radius: var(--radius);
    background: transparent;
    font-size: 14px;
    transition:
      background var(--transition),
      transform var(--transition),
      box-shadow var(--transition);
  }

  ul li a:hover {
    background: var(--hover);
    transform: translateX(2px);
  }

  ul li a span {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (max-width: 480px) {
    .bookmark-sections {
      grid-template-columns: 1fr;
    }
    ul li a {
      padding: 9px 12px;
      font-size: 13px;
    }
  }
</style>

<script>
  const ua = navigator.userAgent;
  const isAndroid = /Android/i.test(ua);
  const isIOS = /iPhone|iPad|iPod/i.test(ua);

  document
    .querySelectorAll<HTMLAnchorElement>(
      "a[data-android-app], a[data-ios-scheme]",
    )
    .forEach((link) => {
      const androidApp = link.dataset.androidApp;
      const iosScheme = link.dataset.iosScheme;
      const webUrl = link.href;

      if (isAndroid && androidApp) {
        link.addEventListener("click", (event) => {
          event.preventDefault();
          const host = webUrl.replace(/^https?:\/\//, "");
          window.location.href =
            `intent://${host}#Intent;scheme=https;package=${androidApp};` +
            `S.browser_fallback_url=${encodeURIComponent(webUrl)};end`;
        });
      } else if (isIOS && iosScheme) {
        link.addEventListener("click", (event) => {
          event.preventDefault();
          const start = Date.now();
          window.location.href = iosScheme;
          setTimeout(() => {
            if (!document.hidden && Date.now() - start < 2000) {
              window.location.href = webUrl;
            }
          }, 800);
        });
      }
      // Desktop (or any device without a matching app link): fall through
      // to the normal href navigation to the website.
    });
</script>
