---
---

<p id="date-pill"><b id="date-weekday"></b><span id="date-rest"></span></p>

<section>
  <p id="prompt"><span id="user-display"></span> |</p>
  <input id="terminal-input" type="text" autocomplete="off" spellcheck="false" />
</section>

<style>
  section {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 16px;
    padding: 10px 16px;
    border-radius: var(--radius);
    background: var(--surface-translucent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    flex: 1 1 auto;
    min-width: 0;
    transition:
      border-color var(--transition),
      box-shadow var(--transition);
  }

  section:focus-within {
    border-color: var(--accent);
    box-shadow:
      var(--shadow),
      0 0 0 3px color-mix(in srgb, var(--accent) 25%, transparent);
  }

  p {
    font-family: var(--mono);
    font-size: 18px;
    color: var(--muted);
    white-space: nowrap;
  }

  #user-display {
    font-weight: 500;
    color: var(--accent);
  }

  #date-pill {
    flex: 0 0 auto;
    margin: 0;
    padding: 10px 16px;
    border-radius: var(--radius);
    background: var(--surface-translucent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    font-family: var(--font);
    font-size: 18px;
    font-weight: 400;
    color: var(--muted);
    white-space: nowrap;
  }

  #date-weekday {
    font-weight: 700;
  }

  #terminal-input {
    background: none;
    border: none;
    font-family: var(--mono);
    font-size: 18px;
    color: var(--text);
    flex: 1;
    min-width: 0;
  }

  #terminal-input:focus {
    outline: none;
  }

  #terminal-input::placeholder {
    color: var(--muted);
  }

  @media (max-width: 1040px) {
    section {
      position: fixed;
      left: 0.75rem;
      right: 0.75rem;
      bottom: max(0.75rem, env(safe-area-inset-bottom));
      width: auto;
      max-width: none;
      flex-direction: row;
      align-items: center;
      gap: 10px;
      padding: 10px 14px;
      z-index: 50;
    }
    p,
    #terminal-input {
      font-size: 15px;
    }
    #terminal-input {
      width: 100%;
    }
    #date-pill {
      font-size: 15px;
      padding: 10px 14px;
    }
  }

  :global(.bookmark-match) {
    opacity: 1 !important;
    transform: scale(1.02) !important;
    transition: all 0.2s ease !important;
    box-shadow: 0 0 0 2px var(--accent) !important;
  }

  :global(.bookmark-nomatch) {
    opacity: 0.35 !important;
    filter: grayscale(70%) !important;
    transform: scale(0.98) !important;
    transition: all 0.3s ease !important;
  }

  :global(.bookmark-nomatch-parent) {
    text-decoration: line-through !important;
    text-decoration-color: var(--muted) !important;
  }

  :global(.bookmark-section a:hover) {
    background: var(--hover) !important;
    opacity: 1 !important;
    filter: none !important;
    transform: translateX(2px) !important;
  }
</style>

<script>
  const PREFIX_RE = /^(?:r:|m:)/;

  const WEEKDAY_ABBR = ["SUN", "MON", "TUES", "WED", "THURS", "FRI", "SAT"];

  function getDateParts(): { weekday: string; rest: string } {
    const now = new Date();
    const weekday = WEEKDAY_ABBR[now.getDay()];
    const month = now.toLocaleDateString("en-US", { month: "short" });
    const date = now.getDate();
    const year = String(now.getFullYear()).slice(-3);
    return { weekday, rest: `${month} ${date} ${year}` };
  }

  function detectBrowser(): string {
    const ua = navigator.userAgent;
    if (ua.includes("Edg/")) return "edge";
    if (ua.includes("Chrome/")) return "chrome";
    if (ua.includes("Firefox/")) return "firefox";
    if (ua.includes("Safari/")) return "safari";
    return "browser";
  }

  function typePlaceholder(input: HTMLInputElement, examples: string[], speed = 50) {
    let exampleIndex = 0;
    let charIndex = 0;

    function step() {
      const current = examples[exampleIndex];
      if (charIndex < current.length) {
        input.placeholder += current.charAt(charIndex);
        charIndex++;
        setTimeout(step, speed);
      } else {
        setTimeout(() => {
          input.placeholder = "";
          charIndex = 0;
          exampleIndex = (exampleIndex + 1) % examples.length;
          step();
        }, 2000);
      }
    }
    step();
  }

  function resetStyles(elements: NodeListOf<HTMLAnchorElement>) {
    elements.forEach((el) => {
      el.classList.remove("bookmark-match", "bookmark-nomatch");
      el.parentElement?.classList.remove("bookmark-nomatch-parent");
    });
  }

  function stripPrefix(value: string): string {
    return value.replace(PREFIX_RE, "");
  }

  function highlightMatches(value: string, elements: NodeListOf<HTMLAnchorElement>) {
    if (value === "") {
      resetStyles(elements);
      return;
    }
    const needle = stripPrefix(value);
    elements.forEach((el) => {
      const isMatch = el.textContent!.toLowerCase().includes(needle);
      el.classList.toggle("bookmark-match", isMatch);
      el.classList.toggle("bookmark-nomatch", !isMatch);
      el.parentElement?.classList.toggle("bookmark-nomatch-parent", !isMatch);
    });
  }

  function navigate(value: string) {
    if (value.startsWith("r:")) {
      const q = value.slice(2).trim();
      window.location.href = `https://google.com/search?q=${encodeURIComponent(`site:reddit.com ${q}`)}`;
      return;
    }
    if (value.startsWith("m:")) {
      const q = value.slice(2).trim();
      window.location.href = `https://google.com/search?q=${encodeURIComponent(`site:myanimelist.net ${q}`)}`;
      return;
    }
    if (/^[\w-]+(\.[\w-]+)+(\/.*)?$/.test(value)) {
      window.location.href = `https://${value}`;
      return;
    }
    window.location.href = `https://google.com/search?q=${encodeURIComponent(value)}`;
  }

  function findBookmarkMatch(value: string, elements: NodeListOf<HTMLAnchorElement>): HTMLAnchorElement | null {
    const needle = stripPrefix(value);
    if (!needle) return null;
    for (const el of elements) {
      if (el.textContent!.toLowerCase().includes(needle)) return el;
    }
    return null;
  }

  function initializeTerminal() {
    const input = document.getElementById("terminal-input") as HTMLInputElement | null;
    const userDisplay = document.getElementById("user-display");
    const dateWeekday = document.getElementById("date-weekday");
    const dateRest = document.getElementById("date-rest");
    if (!input || !userDisplay || !dateWeekday || !dateRest) return;

    userDisplay.textContent = `ryan@${detectBrowser()}`;
    const { weekday, rest } = getDateParts();
    dateWeekday.textContent = weekday;
    dateRest.textContent = ` ${rest}`;

    const examples = [
      "how to tie a tie?",
      "today's weather",
      "search reddit with r:query",
      "search myanimelist with m:query",
      "type a domain to navigate",
      "press ctrl+c to clear",
    ];

    const elements = document.querySelectorAll<HTMLAnchorElement>(".bookmark-section a");
    const history: string[] = [];
    let historyIndex = 0;

    typePlaceholder(input, examples);
    resetStyles(elements);

    input.addEventListener("input", () => {
      highlightMatches(input.value.toLowerCase(), elements);
    });

    input.addEventListener("blur", () => {
      if (input.value === "") resetStyles(elements);
    });

    input.addEventListener("keydown", (event) => {
      if (event.ctrlKey && event.key === "c") {
        input.value = "";
        resetStyles(elements);
        return;
      }

      if (event.key === "ArrowUp") {
        if (historyIndex > 0) {
          historyIndex--;
          input.value = history[historyIndex];
          event.preventDefault();
        }
        return;
      }

      if (event.key === "ArrowDown") {
        if (historyIndex < history.length - 1) {
          historyIndex++;
          input.value = history[historyIndex];
        } else {
          historyIndex = history.length;
          input.value = "";
        }
        event.preventDefault();
        return;
      }

      if (event.key === "Enter") {
        const value = input.value.trim();
        if (!value) return;

        history.push(value);
        historyIndex = history.length;

        const match = findBookmarkMatch(value.toLowerCase(), elements);
        if (match) {
          window.location.href = match.href;
        } else {
          navigate(value);
        }
      }
    });

    const isDesktop = window.matchMedia("(min-width: 1041px)").matches;
    if (isDesktop) {
      input.focus();
      document.addEventListener("keydown", (e) => {
        if (e.target === document.body) input.focus();
      });
    }
  }

  document.addEventListener("DOMContentLoaded", initializeTerminal);
</script>
